        "faq": {
            "title": "Frequently Asked Questions",
            "items": {
                "free": {
                    "question": "Is Snipit free to use?",
                    "answer": "Yes! Snipit is completely free to use. You can use it for personal or commercial projects without any cost."
                },
                "expiration": {
                    "question": "How long do snippets last?",
                    "answer": "You can choose the expiration time for each snippet, ranging from 1 hour to 1 year. You can also create snippets that never expire."
                },
                "secure": {
                    "question": "Is my code secure?",
                    "answer": "We take security seriously. All snippets are encrypted in transit and at rest. Password-protected snippets add an extra layer of security."
                },
                "edit": {
                    "question": "Can I edit my snippets later?",
                    "answer": "Yes, if you are logged in when you create a snippet, you can edit or delete it later from your dashboard."
                }
            }
        }
